{
  "name": "copilot-manager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch server/main.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production bun server/main.ts"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "clipboardy": "^5.0.0",
    "consola": "^3.4.2",
    "fetch-event-stream": "^0.1.5",
    "gpt-tokenizer": "^3.0.1",
    "hono": "^4.9.9",
    "lucide-react": "^0.513.0",
    "proxy-from-env": "^1.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "srvx": "^0.8.9",
    "tiny-invariant": "^1.3.3",
    "undici": "^7.16.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/bun": "^1.2.23",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.3",
    "vite": "^6.3.5"
  }
}
